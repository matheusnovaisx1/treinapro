# ----- Supabase -----
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key   # NUNCA expor no client

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WhatsApp, marca própria, streak, PDF e página pública não exigem nenhuma variável
# de ambiente nova — tudo é configurado dentro do app, em Configurações.

# ----- Stripe -----
# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Dashboard > Developers > Webhooks (ou `stripe listen` no CLI)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Products > Pro (3 alunos) > Price ID
STRIPE_PRO_PRICE_ID=price_xxx
# Products > Premium (ilimitado) > Price ID
STRIPE_PREMIUM_PRICE_ID=price_xxx
